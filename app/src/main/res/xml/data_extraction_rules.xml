<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- No Google Drive / cloud backup. -->
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>

    <!-- No local device-to-device migration. -->
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>